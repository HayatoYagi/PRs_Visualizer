root = true

[*]
charset = utf-8
end_of_line = lf
indent_size = 4
indent_style = space
insert_final_newline = true
max_line_length = 140
trim_trailing_whitespace = true

[*.kt]
ktlint_standard_multiline-expression-wrapping = disabled
ktlint_standard_function-signature = disabled
ktlint_standard_filename = disabled
ktlint_standard_chain-method-continuation = disabled

# Allow PascalCase for @Composable functions in UI code
[composeApp/src/jvmMain/kotlin/**/ui/**/*.kt]
ktlint_function_naming_ignore_when_annotated_with = Composable

# Allow PascalCase for @Composable functions in root UI files (App.kt)
[composeApp/src/jvmMain/kotlin/io/github/hayatoyagi/prvisualizer/App.kt]
ktlint_function_naming_ignore_when_annotated_with = Composable

[{*.kts,build.gradle.kts,settings.gradle.kts}]
indent_size = 4

[*.{yml,yaml}]
indent_size = 2
